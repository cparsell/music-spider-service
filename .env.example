# This is used for development purposes, but you can use it to set your own environment variables for the app. 

# Copy this file to .env.local and fill in real values.
#
# Everything here is a *fallback* - lib/settings.js only reads these when the
# corresponding field in the Settings tab (persisted to data/settings.json)
# is blank. A saved setting always wins over the env var.

# --- Server ---
# Port the standalone server listens on (Dockerfile hardcodes 6100 via ENV).
PORT=6100
# Where settings.json / top-artists-cache.json are read/written.
# Defaults to ./data if unset.
DATA_DIR=./data

# --- Tautulli (top-artists source) ---
TAUTULLI_URL=http://your-tautulli-host:8181
TAUTULLI_API_KEY=
TAUTULLI_MUSIC_SECTION_ID=

# --- Spotify (top-artists source + OAuth) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:6100/api/spotify/callback

# --- Ticketmaster (event search) ---
TICKETMASTER_API_KEY=

# --- Resident Advisor (event search) ---
RA_REGION=

# --- Location for event search ---
LAT_LONG=37.8715226,-122.2730420
RADIUS=30
UNITS=miles

# --- Weekly email digest ---
EMAIL_RECIPIENT=

# --- Google Calendar sync ---
CALENDAR_ID=
# OAuth (googleIntegrationMode=oauth) - requires HTTPS on the redirect URI
# once accessed from anywhere other than 127.0.0.1/localhost.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:6100/api/google/callback
# Apps Script webhook (googleIntegrationMode=appsScript) - see
# apps-script/Code.gs. Simpler alternative to OAuth above; no HTTPS needed
# on this app's end.
APPS_SCRIPT_WEBHOOK_URL=
APPS_SCRIPT_SHARED_SECRET=

# --- Weekly webhook digest (Discord, Home Assistant, etc.) ---
WEBHOOK_URL=
